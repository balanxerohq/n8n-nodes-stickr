{
    "name": "n8n-nodes-stickr",
    "version": "0.0.1-alpha.2",
    "description": "Official STICKR Trigger Node for n8n",
    "license": "MIT",
    "homepage": "https://developers.stickr.de/connectors/n8n",
    "keywords": [
        "n8n-community-node-package",
        "n8n-nodes",
        "stickr",
        "webhooks",
        "trigger"
    ],
    "author": {
        "name": "balanxerohq",
        "email": "hello@stickr.de"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/balanxerohq/n8n-nodes-stickr.git"
    },
    "bugs": {
        "url": "https://github.com/balanxerohq/n8n-nodes-stickr/issues"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/StickrApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/StickrTrigger/StickrTrigger.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
